# Configuration Bipbip Recharge CI (bipbiprecharge.ci)
# Copier ce fichier en .env et remplir les valeurs

# Port du serveur (souvent 3000, ou celui configuré derrière Nginx)
PORT=3000

# Token du bot Telegram (obtenir via @BotFather)
TELEGRAM_BOT_TOKEN=votre_token_telegram

# ID Telegram de l'admin (pour recevoir les notifications)
ADMIN_CHAT_ID=votre_chat_id
