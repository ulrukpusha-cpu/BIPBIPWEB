# Configuration Bipbip Recharge CI
# En production : NODE_ENV=production, SESSION_SECRET, CORS_ORIGIN, et identifiants DB (Supabase ou MySQL)

# Port du serveur
PORT=3000

# Production (recommandé)
# NODE_ENV=production
# SESSION_SECRET=generer_une_cle_longue_et_aleatoire
# CORS_ORIGIN=https://votre-domaine.com,https://t.me

# Token du bot Telegram
TELEGRAM_BOT_TOKEN=votre_token_bot

# ID Telegram de l'admin (un seul)
# ADMIN_CHAT_ID=votre_chat_id
# Plusieurs admins : liste séparée par des virgules (prioritaire si défini)
# ADMIN_CHAT_IDS=123456789,987654321,111222333
ADMIN_CHAT_ID=votre_chat_id

# ---------- Base de données (optionnel) ----------
# Priorité : USE_SUPABASE > USE_MYSQL > fichier data/orders.json

# --- Supabase (recommandé : hébergé, gratuit) ---
# USE_SUPABASE=true
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   (clé secrète, jamais côté client)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[MDP]@aws-0-xx.pooler.supabase.com:6543/postgres  (pour scripts/run-momo-schema.js)

# --- MySQL ---
# USE_MYSQL=true
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=votre_mot_de_passe
# DB_NAME=bipbip_recharge

# ---------- MTN MoMo (paiement, optionnel) ----------
# Nécessite Supabase (table momo_transactions). Côte d'Ivoire: mtnciv, XOF.
# MTN_SUBSCRIPTION_KEY=
# MTN_API_USER=
# MTN_API_KEY=
# MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
# MTN_TARGET_ENVIRONMENT=mtnciv
# MTN_CALLBACK_SECRET=   (optionnel, pour valider le callback PUT)
# BIPBIP_MOMO_PHONE=05 XX XX XX XX   (numéro sur lequel tu reçois, affiché sur le site)

# Clé secrète pour les routes admin (actualités/annonces : pending, approve, valider, refuser)
# ADMIN_SECRET_KEY=ta_cle_secrete
# Côté client : header X-Admin-Key: ta_cle_secrete

# Ingest actualités (OpenClaw, API, météo) : clé pour POST /api/actualites/ingest
# Si absent, la route ingest utilise ADMIN_SECRET_KEY. Header : X-Ingest-Key: <clé>
# INGEST_SECRET_KEY=ta_cle_ingest

# Flux RSS pour actualités auto (cron : node cron/fetchNewsRss.js)
# RSS_FEED_URL=https://www.fratmat.info/feed/
# ou plusieurs : RSS_FEED_URLS=https://feed1.xml,https://feed2.xml

# ---------- Paiement crypto + TON Connect (Web App) ----------
# Conversion XOF → TON (API /api/rates/ton, style pro wallet) — optionnel, défauts ci-dessous
# XOF_PER_USD=600
# TON_FALLBACK_USD=7
# Une seule adresse pour USDT / USDC / TON (affichée pour les trois boutons)
# CRYPTO_DEPOSIT_ADDRESS=
# Libellé réseau affiché (ex. TON, TRC20, ERC-20)
# CRYPTO_DEPOSIT_NETWORK=TON
# Estimation FCFA par 1 USDT (optionnel)
# CRYPTO_FCFA_PER_USDT=650
# URL Djamo (optionnel, défaut pay.djamo.com)
# DJAMO_PAY_URL=https://pay.djamo.com/pkbyg
# Lien secours @wallet si le script TON Connect ne charge pas
# TELEGRAM_WALLET_URL=https://t.me/wallet
# HTTPS obligatoire en prod pour le manifest TON Connect
# PUBLIC_BASE_URL=https://bipbiprecharge.ci
# Nom du bot sans @ (retour Mini App après connexion wallet)
# TELEGRAM_BOT_USERNAME=mon_bot
# Nom / icône dans le manifest TON Connect (optionnel)
# TON_CONNECT_APP_NAME=Bipbip Recharge CI
# TON_CONNECT_ICON_URL=https://ton.org/download/ton_symbol.png
# Supabase / MySQL : exécuter database/migration-orders-payment-method.sql (ou version MySQL)
